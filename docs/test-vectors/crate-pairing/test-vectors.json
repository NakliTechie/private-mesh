{
  "$schema_version": "1.0",
  "source_spec": "../../specs/crate-pairing-protocol-v1.0.md",
  "vectors": [
    {
      "name": "valid-v1",
      "token": "CRATE-PAIR-",
      "expected_error": null,
      "note": "Verbatim from crate-pairing-protocol-v1.0.md \u00a7'Test vectors'. Synthetic, not for production."
    },
    {
      "name": "invalid-malformed-json",
      "token": "CRATE-PAIR-aGVsbG8gd29ybGQ=",
      "expected_error": "E_TOKEN_FORMAT",
      "note": "Base64 decodes to ASCII 'hello world', not JSON. Per spec example."
    },
    {
      "name": "invalid-wrong-version",
      "token": "CRATE-PAIR-",
      "expected_error": "E_PROTOCOL_VERSION",
      "note": "v=99 is unsupported. Daemon must reject with E_PROTOCOL_VERSION per error table."
    },
    {
      "name": "invalid-expired",
      "token": "CRATE-PAIR-",
      "expected_error": "E_TOKEN_EXPIRED",
      "note": "issued_at and expires_at both in Jan 2024. Per spec example."
    },
    {
      "name": "invalid-missing-secret",
      "token": "CRATE-PAIR-",
      "expected_error": "E_TOKEN_FORMAT",
      "note": "Payload lacks the required 'secret' field; falls under E_TOKEN_FORMAT (schema mismatch)."
    },
    {
      "name": "invalid-wrong-type",
      "token": "CRATE-PAIR-",
      "expected_error": "E_TOKEN_FORMAT",
      "note": "type field is not 'crate.pairing.token'; falls under E_TOKEN_FORMAT (schema mismatch)."
    },
    {
      "name": "invalid-bad-prefix",
      "token": "PAIR-",
      "expected_error": "E_TOKEN_FORMAT",
      "note": "Token does not begin with the literal 'CRATE-PAIR-' prefix the spec mandates."
    }
  ]
}
